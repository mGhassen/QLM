{
  "name": "@guepard/extension-mongodb",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/driver.js",
  "types": "./dist/driver.d.ts",
  "exports": {
    ".": {
      "bun": "./src/driver.ts",
      "types": "./dist/driver.d.ts",
      "default": "./dist/driver.js"
    }
  },
  "scripts": {
    "lint": "echo \"no lint configured\"",
    "test": "vitest run --coverage --passWithNoTests --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run --passWithNoTests __tests__/driver.integration.test.ts",
    "build": "tsc -p tsconfig.build.json"
  },
  "contributes": {
    "datasources": [
      {
        "id": "mongodb",
        "name": "MongoDB",
        "description": "Connect to MongoDB databases",
        "tags": [
          "NoSQL"
        ],
        "icon": "media/mongodb.svg",
        "drivers": [
          "mongodb.default"
        ],
        "docsUrl": "https://www.mongodb.com/docs/manual/reference/connection-string/"
      }
    ],
    "drivers": [
      {
        "id": "mongodb.default",
        "name": "MongoDB (Node)",
        "description": "Default Node runtime MongoDB driver",
        "runtime": "node",
        "entry": "./dist/driver.js"
      }
    ]
  },
  "dependencies": {
    "@guepard/extensions-sdk": "workspace:*",
    "mongodb": "^6.9.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "catalog:",
    "testcontainers": "^10.12.0",
    "vitest": "catalog:"
  }
}