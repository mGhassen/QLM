{
  "name": "@guepard/repository-supabase",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --logHeapUsage --coverage --silent --passWithNoTests",
    "test:watch": "vitest"
  },
  "exports": {
    ".": "./src/index.ts",
    "./jwt-signer": "./src/jwt-signer.ts"
  },
  "dependencies": {
    "@guepard/domain": "workspace:*",
    "@guepard/supabase": "workspace:*",
    "@supabase/supabase-js": "catalog:",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "sqids": "^0.3.0",
    "uuid": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@guepard/eslint-config": "workspace:*",
    "@guepard/prettier-config": "workspace:*",
    "@guepard/tsconfig": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@guepard/prettier-config",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}