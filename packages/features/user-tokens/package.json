{
  "name": "@guepard/user-tokens",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --logHeapUsage --coverage --silent --passWithNoTests"
  },
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./components": "./src/components/index.ts"
  },
  "dependencies": {
    "@guepard/domain": "workspace:*",
    "@guepard/settings-shell": "workspace:*"
  },
  "devDependencies": {
    "@guepard/eslint-config": "workspace:*",
    "@guepard/i18n": "workspace:*",
    "@guepard/prettier-config": "workspace:*",
    "@guepard/shared": "workspace:*",
    "@guepard/tailwind-config": "workspace:*",
    "@guepard/tsconfig": "workspace:*",
    "@guepard/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@storybook/react": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-istanbul": "catalog:",
    "date-fns": "catalog:",
    "eslint": "^9.39.0",
    "i18next": "^25.6.0",
    "jsdom": "^27.1.0",
    "lucide-react": "^0.552.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "sonner": "^2.0.7",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "prettier": "@guepard/prettier-config",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}