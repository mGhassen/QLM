{
  "name": "@qlm/billing",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "start": "docker run --rm -it --name=stripe -v ~/.config/stripe:/root/.config/stripe stripe/stripe-cli:latest listen --forward-to http://host.docker.internal:3000/api/billing/webhook"
  },
  "exports": {
    "./components": "./src/components/index.ts",
    "./services": "./src/services/index.ts"
  },
  "dependencies": {
    "@qlm/shared": "workspace:*",
    "date-fns": "catalog:",
    "lucide-react": "^0.552.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@qlm/eslint-config": "workspace:*",
    "@qlm/i18n": "workspace:*",
    "@qlm/prettier-config": "workspace:*",
    "@qlm/supabase": "workspace:*",
    "@qlm/tailwind-config": "workspace:*",
    "@qlm/tsconfig": "workspace:*",
    "@qlm/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@storybook/react": "catalog:",
    "@storybook/react-vite": "catalog:",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.3.0",
    "@supabase/supabase-js": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next-themes": "0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "sonner": "^2.0.7",
    "stripe": "^19.2.1",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "prettier": "@qlm/prettier-config",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}