{
  "name": "@qlm/integrations",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@qlm/domain": "workspace:*",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@qlm/eslint-config": "workspace:*",
    "@qlm/i18n": "workspace:*",
    "@qlm/prettier-config": "workspace:*",
    "@qlm/shared": "workspace:*",
    "@qlm/tailwind-config": "workspace:*",
    "@qlm/tsconfig": "workspace:*",
    "@qlm/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@storybook/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "^9.39.0",
    "i18next": "^25.6.0",
    "lucide-react": "^0.552.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.3",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "prettier": "@qlm/prettier-config",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}