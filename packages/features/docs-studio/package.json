{
  "name": "@qlm/docs-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "exports": {
    ".": "./src/index.ts",
    "./actions": "./src/actions.ts",
    "./paths": "./src/paths.ts",
    "./pages": "./src/components/pages.ts",
    "./loader": "./src/lib/loader.ts",
    "./lib/*": "./src/lib/*",
    "./server": "./src/server/api-handlers.ts",
    "./DocStudio": "./src/components/docs/studio/DocStudio.tsx",
    "./DocLayout": "./src/components/docs/DocLayout.tsx",
    "./styles": "./src/styles/index.css",
    "./supabase/docs": "./src/supabase/docs.ts"
  },
  "dependencies": {
    "@qlm/ui": "workspace:*",
    "@qlm/supabase": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tiptap/core": "3.26.0",
    "@tiptap/extension-color": "3.26.0",
    "@tiptap/extension-image": "3.26.0",
    "@tiptap/extension-link": "3.26.0",
    "@tiptap/extension-placeholder": "3.26.0",
    "@tiptap/extension-text-align": "3.26.0",
    "@tiptap/extension-text-style": "3.26.0",
    "@tiptap/extension-underline": "3.26.0",
    "@tiptap/pm": "3.26.0",
    "@tiptap/react": "3.26.0",
    "@tiptap/starter-kit": "3.26.0",
    "cheerio": "^1.2.0",
    "domhandler": "^5.0.3",
    "lucide-react": "^0.552.0",
    "pdf-parse": "^1.1.1",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@qlm/eslint-config": "workspace:*",
    "@qlm/prettier-config": "workspace:*",
    "@qlm/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "^9.39.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@qlm/prettier-config"
}
