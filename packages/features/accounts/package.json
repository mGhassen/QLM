    "./hooks/*": "./src/hooks/*.ts",
    "./api": "./src/server/api.ts",
    "./schema": "./src/schema/index.ts",
    "./actions": "./src/server/actions/index.ts",
    "./components": "./src/components/index.ts",
    "./policies": "./src/server/policies/index.ts"
  },
