{
  "name": "@qlm/shell-topbar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "clean": "git clean -xdf .turbo node_modules",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --logHeapUsage --coverage --silent --passWithNoTests"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "dependencies": {
    "@qlm/domain": "workspace:*",
    "@qlm/shell-runtime": "workspace:*",
    "@qlm/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "catalog:",
    "react-hook-form": "^7.66.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@qlm/eslint-config": "workspace:*",
    "@qlm/i18n": "workspace:*",
    "@qlm/prettier-config": "workspace:*",
    "@qlm/shared": "workspace:*",
    "@qlm/tailwind-config": "workspace:*",
    "@qlm/tsconfig": "workspace:*",
    "@storybook/react": "catalog:",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "jsdom": "^27.1.0",
    "lucide-react": "^0.552.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^16.2.3",
    "storybook": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "prettier": "@qlm/prettier-config",
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}