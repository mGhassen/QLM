{
  "name": "qlm",
  "description": "The console for the QLM Platform",
  "homepage": "https://qlm.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mGhassen/QLM"
  },
  "bugs": {
    "url": "https://github.com/mGhassen/QLM/issues"
  },
  "keywords": [
    "ai",
    "agentic-ai",
    "database",
    "sql",
    "data-engineering",
    "mysql",
    "mongodb",
    "nosql",
    "clickhouse",
    "postgresql",
    "sqlserver",
    "duckdb"
  ],
  "version": "0.2.3",
  "private": true,
  "sideEffects": false,
  "engines": {
    "node": ">=22.x"
  },
  "author": {
    "url": "https://qlm.dev",
    "name": "QLM"
  },
  "scripts": {
    "pretest": "pnpm exec playwright install chromium firefox webkit || true",
    "turbo": "turbo",
    "build": "turbo build --cache-dir=.turbo",
    "clean": "git clean -xdf node_modules dist",
    "clean:workspaces": "turbo clean",
    "dev": "cross-env FORCE_COLOR=1 turbo dev --parallel",
    "format": "turbo format --cache-dir=.turbo --continue -- --cache --cache-location=\"node_modules/.cache/.prettiercache\"",
    "format:fix": "turbo format --cache-dir=.turbo --continue -- --write --cache --cache-location=\"node_modules/.cache/.prettiercache\"",
    "lint": "turbo lint --cache-dir=.turbo --continue -- --cache --cache-location \"node_modules/.cache/.eslintcache\" && manypkg check",
    "lint:fix": "turbo lint --cache-dir=.turbo --continue -- --fix --cache --cache-location \"node_modules/.cache/.eslintcache\" && manypkg fix",
    "typecheck": "turbo typecheck --cache-dir=.turbo",
    "test": "turbo test --cache-dir=.turbo",
    "storybook": "pnpm --filter @qlm/storybook-config storybook",
    "build-storybook": "pnpm --filter @qlm/storybook-config build-storybook",
    "extensions:build": "node tooling/extensions/build.js",
    "update": "pnpm update -r",
    "syncpack:list": "pnpm dlx syncpack list-mismatches",
    "syncpack:fix": "pnpm dlx syncpack fix-mismatches",
    "supabase:web:start": "pnpm --filter web supabase:start",
    "supabase:web:stop": "pnpm --filter web supabase:stop",
    "supabase:web:typegen": "pnpm --filter web supabase:typegen",
    "supabase:web:reset": "pnpm --filter web supabase:reset",
    "stripe:listen": "pnpm --filter '@qlm/billing' start",
    "supabase:web:test": "pnpm --filter web supabase:test",
    "env:generate": "turbo gen env",
    "env:validate": "turbo gen validate-env",
    "check": "pnpm format:fix && pnpm format && pnpm lint && pnpm typecheck && pnpm build && turbo test --filter=!e2e --cache-dir=.turbo && pnpm check:rls && pnpm check:audit",
    "check:ci": "pnpm format && pnpm lint && pnpm typecheck && pnpm build && turbo test --filter=!e2e --cache-dir=.turbo && pnpm check:rls && pnpm check:audit",
    "check:rls": "node scripts/check-rls.mjs",
    "check:audit": "pnpm audit --prod --audit-level=high",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "security:react": "ts-node scripts/check-react-vulns.ts",
    "security:react:audit": "ENABLE_PNPM_AUDIT=true ts-node scripts/check-react-vulns.ts",
    "server:dev": "pnpm --filter server dev",
    "web:dev": "pnpm --filter web dev",
    "studio:dev": "pnpm --filter web dev",
    "studio:build": "pnpm --filter web build",
    "studio:reset": "pnpm --filter web docs:reset",
    "studio:seed": "pnpm --filter web docs:seed",
    "studio:seed:admin": "pnpm --filter web docs:seed:admin",
    "studio:seed:data": "pnpm --filter web docs:seed:data",
    "studio:import": "pnpm --filter web docs:import",
    "preview": "bash -c 'set -a && . ./.preview.env && set +a && pnpm --filter web supabase:start && cross-env FORCE_COLOR=1 turbo dev --parallel'",
    "preview:stop": "bash scripts/sdd/teardown-preview.sh \"$PWD\"",
    "e2e": "pnpm --filter e2e test",
    "e2e:ui": "pnpm --filter e2e test:ui",
    "docker:build": "docker buildx build --platform linux/amd64 -t gueparf-enterprise -f Dockerfile .",
    "docker:run": "docker run -p 3000:3000 --env-file apps/server/.env gueparf-enterprise"
  },
  "prettier": "@qlm/prettier-config",
  "packageManager": "pnpm@10.18.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@duckdb/node-api",
      "@sentry/cli",
      "@tailwindcss/oxide",
      "core-js",
      "core-js-pure",
      "electron",
      "esbuild",
      "msw",
      "onnxruntime-node",
      "protobufjs",
      "sentry",
      "sharp",
      "supabase",
      "@swc/core",
      "unrs-resolver"
    ],
    "overrides": {
      "fast-xml-builder": "^1.1.7",
      "fast-uri": "^3.1.2",
      "@opentelemetry/sdk-node": "^0.217.0",
      "@opentelemetry/exporter-prometheus": "^0.217.0",
      "@tanstack/router-core": "1.169.2",
      "@tanstack/react-router": "1.169.2",
      "protobufjs": "^8.0.2"
    }
  },
  "devDependencies": {
    "@qlm/prettier-config": "workspace:*",
    "@manypkg/cli": "^0.25.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@turbo/gen": "^2.6.0",
    "@types/node": "catalog:",
    "@types/semver": "^7.5.8",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.1",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "semver": "^7.7.1",
    "ts-node": "^10.9.2",
    "turbo": "^2.6.0",
    "typescript": "catalog:"
  },
  "overrides": {
    "react-is": "19.0.0",
    "p-map": "^7.0.4",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.38.6",
    "@codemirror/commands": "^6.4.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lang-text": "^6.0.1",
    "protobufjs": "^8.0.2"
  },
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/**",
      "tooling/*"
    ],
    "catalog": {
      "@storybook/addon-docs": "^10.3.5",
      "@storybook/addon-links": "^10.3.4",
      "@storybook/react": "^10.3.4",
      "@storybook/react-vite": "^10.3.4",
      "@supabase/supabase-js": "^2.86.2",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-query-devtools": "^5.91.1",
      "@tanstack/react-router": "1.169.2",
      "@types/node": "^24.9.2",
      "@types/react": "^19.2.3",
      "@types/react-dom": "^19.2.3",
      "@vitest/coverage-istanbul": "^4.0.18",
      "ai": "6.0.150",
      "date-fns": "^4.1.0",
      "msw": "^2.12.4",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "storybook": "^10.3.4",
      "supabase": "^2.65.6",
      "typescript": "^5.9.3",
      "uuid": "^11.0.3",
      "vite": "^7.1.12",
      "vitest": "^4.0.18",
      "zod": "^4.0.0"
    }
  }
}