# Secret vault (integrations credentials). Required — server refuses to start without it.
# Prefer: openssl rand -hex 32  (64 hex chars = 32 bytes)
# Dev-only: any string is scrypt-stretched (see apps/server/src/lib/secret-vault.ts)
QLM_SECRET_VAULT_KEY=

# Storage
QWERY_STORAGE_DIR=qwery.db

# Azure OpenAI
AZURE_API_KEY=
AZURE_RESOURCE_NAME=
AZURE_OPENAI_DEPLOYMENT=

# Anthropic
ANTHROPIC_API_KEY=

# Telemetry
QWERY_TELEMETRY_ENABLED=false
QWERY_TELEMETRY_DEBUG=false

# Default model
DEFAULT_MODEL=azure/gpt-5-mini

# SUPABASE
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
