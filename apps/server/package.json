{
  "name": "server",
  "version": "0.2.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --check \"**/*.ts\"",
    "format:fix": "prettier --write \"**/*.ts\"",
    "test": "vitest run --logHeapUsage --coverage --silent",
    "test:watch": "vitest",
    "mcp": "npx @modelcontextprotocol/inspector"
  },
  "prettier": "@guepard/prettier-config",
  "dependencies": {
    "@guepard/agent-factory-sdk": "workspace:*",
    "@guepard/domain": "workspace:*",
    "@guepard/extensions-loader": "workspace:*",
    "@guepard/extensions-sdk": "workspace:*",
    "@guepard/integrations-drivers": "workspace:*",
    "@guepard/repository-supabase": "workspace:*",
    "@guepard/shared": "workspace:*",
    "@guepard/supabase": "workspace:*",
    "@guepard/telemetry": "workspace:*",
    "@hono/zod-validator": "^0.4.2",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@supabase/supabase-js": "catalog:",
    "class-transformer": "^0.5.1",
    "hono": "^4.10.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@guepard/eslint-config": "workspace:*",
    "@guepard/prettier-config": "workspace:*",
    "@guepard/tsconfig": "workspace:*",
    "@types/bun": "latest",
    "@vitest/coverage-istanbul": "catalog:",
    "eslint": "^9.39.0",
    "pino-pretty": "^13.1.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.x"
  }
}