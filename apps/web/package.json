{
  "name": "web",
  "private": false,
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production vite build",
    "dev": "vite dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix .",
    "start": "vite preview",
    "start:with-env": "pnpm with-env pnpm start",
    "with-env": "dotenv -e ./.env --",
    "typecheck": "tsc",
    "format": "prettier --check \"**/*.{ts,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run --logHeapUsage --coverage --silent --passWithNoTests",
    "test:watch": "vitest",
    "supabase": "supabase",
    "supabase:start": "supabase status || supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase status || supabase start && supabase db reset",
    "supabase:status": "supabase status",
    "supabase:test": "supabase db test",
    "supabase:db:lint": "supabase db lint",
    "supabase:deploy": "supabase link --project-ref $SUPABASE_PROJECT_REF && supabase db push",
    "supabase:typegen": "pnpm run supabase:typegen:packages",
    "supabase:typegen:packages": "supabase gen types typescript --local > ../../packages/supabase/src/database.types.ts",
    "supabase:db:dump:local": "supabase db dump --local --data-only",
    "docs:reset": "node scripts/docs/reset-db.cjs",
    "docs:seed": "node scripts/docs/reset-and-seed.cjs",
    "docs:seed:admin": "node scripts/docs/create-admin-user.cjs",
    "docs:seed:data": "tsx scripts/docs/seed-data.ts",
    "docs:import": "tsx scripts/docs/import-doc.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.3",
