# Base URL of the web app under test
E2E_BASE_URL=http://localhost:3000

# If true, Playwright will NOT start its own dev server and will
# expect one already running at E2E_BASE_URL.
E2E_REUSE_SERVER=false

# Mailpit REST endpoint used to fetch Supabase confirmation emails.
# Default matches `[inbucket] port = 54324` in apps/web/supabase/config.toml
# (the `inbucket` config key is historical — Supabase CLI ships Mailpit now).
# Override only if you changed the local Supabase config.
MAILPIT_URL=http://127.0.0.1:54324

# Supabase admin access, used by the invitation-and-join spec to capture
# the `invite_token` that would normally arrive by email. Falls back to
# reading these values out of apps/web/.env.local if unset here, so most
# local runs don't need to touch this file.
#
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_SERVICE_ROLE_KEY=
